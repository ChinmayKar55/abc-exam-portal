# ── Copy this to .env.production on your VPS — NEVER commit .env.production ──

# Database (postgres container)
DB_USER=abc_exam
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=abc_exam

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Auth
JWT_SECRET=CHANGE_ME_32_BYTES_RANDOM_HEX
JWT_EXPIRY_MIN=15
REFRESH_TOKEN_EXPIRY_DAYS=7

# Payment
PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.com

# Storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=/app/storage

# Public URLs (must match your actual domains)
FRONTEND_URL=https://student.yourdomain.com
ADMIN_URL=https://admin.yourdomain.com

# Container registry (GitHub Container Registry)
REGISTRY=ghcr.io/your-github-username
API_TAG=latest
STUDENT_TAG=latest
ADMIN_TAG=latest
