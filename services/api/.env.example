# Server
PORT=8081
ENV=development

# Database
DB_URL=postgres://postgres:password@localhost:5432/abc_exam?sslmode=disable

# Redis
REDIS_URL=localhost:6379
REDIS_PASSWORD=

# Auth
JWT_SECRET=your-256-bit-secret-here
JWT_EXPIRY_MIN=15
REFRESH_TOKEN_EXPIRY_DAYS=7

# Payment
# Use 'mock' for local dev, 'razorpay' for test/live integration
PAYMENT_PROVIDER=mock
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@abcexam.com

# Storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./storage

# Frontend URLs
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
